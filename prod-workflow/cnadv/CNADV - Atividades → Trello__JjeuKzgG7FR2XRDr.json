    {
      "parameters": {
        "jsCode": "const token = $input.first().json.bearer;\nif (!token) throw new Error('Token não encontrado');\n\n// Pega parâmetros do webhook (modo de operação)\nconst body = $('Webhook').first().json.body || {};\nconst modo = body.modo || 'modulos'; // modulos | campos | dados | tudo\nconst modulo = body.modulo || null;\nconst page = body.page || 0;\nconst pageSize = body.pageSize || 20;\nconst criterio = body.criterio || null;\n\nreturn [{ json: { bearer: token, modo, modulo, page, pageSize, criterio } }];"
      },
