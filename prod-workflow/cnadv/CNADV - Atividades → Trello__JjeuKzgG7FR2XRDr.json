      "parameters": {
        "jsCode": "// Verifica se tem data válida para decidir se chama o nó de data\nconst dataVenc = $('Monta Card').first().json.dataVencimento;\nconst card = $input.first().json;\n\nconsole.log(`✅ Card criado: ${card.name} | ID: ${card.id} | Prazo: ${dataVenc || 'sem data'}`);\nreturn [{ json: { sucesso: true, card_id: card.id, card_url: card.shortUrl, tem_data: !!dataVenc } }];"
