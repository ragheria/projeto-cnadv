    {
      "parameters": {
        "jsCode": "const token = $input.first().json.bearer;\nif (!token) throw new Error('Token não encontrado');\n\n// Data de hoje no formato DD/MM/YYYY para o critério\nconst hoje = new Date();\nconst dd = String(hoje.getDate()).padStart(2, '0');\nconst mm = String(hoje.getMonth() + 1).padStart(2, '0');\nconst yyyy = hoje.getFullYear();\nconst hojeStr = `${dd}/${mm}/${yyyy}`;\n\nconsole.log(`Buscando atividades com prazo >= ${hojeStr}`);\n\nreturn [{ json: { bearer: token, hoje: hojeStr } }];"
      },
