      "id": "948f1f3e-f13a-4c9a-a621-504f96fd9fbf",
      "name": "GET Atividades",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        256
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extrai registros da estrutura real: [{ rows: [...], listSize, modulo }]\nconst response = $input.first().json;\nlet registros = [];\n\nif (Array.isArray(response) && response[0]?.rows) {\n  registros = response[0].rows;\n} else if (response.rows) {\n  registros = response.rows;\n} else if (Array.isArray(response)) {\n  registros = response;\n}\n\nconsole.log(`${registros.length} atividades encontradas`);\nreturn registros.map(r => ({ json: r }));"
      },
      "id": "1f2e7e20-868a-473e-b2f4-2e4a60797ad8",
      "name": "Extrai Registros",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        464,
        256
      ]
    },
    {
      "parameters": {
        "jsCode": "// Deduplicação pelo ID numérico — único e estável\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.idsProcessados) staticData.idsProcessados = [];\n\n// Mantém últimos 3000 IDs\nif (staticData.idsProcessados.length > 3000) {\n  staticData.idsProcessados = staticData.idsProcessados.slice(-3000);\n}\n\nconst itens = $input.all();\nconst novos = [];\n\nfor (const item of itens) {\n  const id = String(item.json.id);\n  if (!id || id === 'undefined') { novos.push(item); continue; }\n  if (!staticData.idsProcessados.includes(id)) {\n    staticData.idsProcessados.push(id);\n    novos.push(item);\n  }\n}\n\nconsole.log(`${novos.length} novas de ${itens.length} total`);\nreturn novos.length > 0 ? novos : [];"
      },
      "id": "2f886818-a973-4253-98f5-2d8fb41e8731",
      "name": "Deduplicação",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        256
      ]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\n\n// --- TIPO pelo prefixo do assunto ---\n// Exemplos reais: 'PRZ - ...', 'PTE - ...', 'PRE - ...', 'SOLIC - ...'\nconst assunto = r.assunto || '';\nconst prefixo = assunto.split(' - ')[0].trim();\n\nconst tipoMap = {\n  'PRZ': { emoji: '⏰', label: 'Prazo', cor: 'red' },\n  'PTE': { emoji: '📤', label: 'Protocolo', cor: 'blue' },\n  'PRE': { emoji: '🚫', label: 'Renúncia', cor: 'orange' },\n  'SOLIC': { emoji: '📋', label: 'Solicitação', cor: 'yellow' },\n  'AUD': { emoji: '⚖️', label: 'Audiência', cor: 'purple' },\n  'REU': { emoji: '🤝', label: 'Reunião', cor: 'green' }\n};\nconst tipo = tipoMap[prefixo] || { emoji: '📌', label: 'Atividade', cor: 'blue' };\n\n// --- TÍTULO ---\n// Usa o assunto completo (já tem o processo no PRZ: \"PRZ - 0005308-... - PROMOTEC - ...\")\nconst titulo = `${tipo.emoji} ${assunto}`.substring(0, 255);\n\n// --- LIMPEZA da observação (ainda tem HTML residual) ---\nconst obsRaw = r.observacao || '';\nconst obsLimpa = obsRaw\n  .replace(/<[^>]+>/g, ' ')     // remove tags HTML\n  .replace(/&nbsp;/g, ' ')      // remove entidades HTML\n  .replace(/&amp;/g, '&')\n  .replace(/\\s+/g, ' ')         // colapsa espaços\n  .trim()\n  .substring(0, 800);           // limita tamanho\n\n// --- DESCRIÇÃO ---\nconst processo = r['processo.pasta'] || 'N/A';\nconst cliente = r['pessoa.nome'] || 'N/A';\nconst responsavel = r['proprietario.nome'] || 'N/A';\nconst dataCriacao = r.data || 'N/A';\nconst prazoFatal = r.dataPrazoFatal || 'N/A';\n\nconst descricao = [\n  `📂 Processo: ${processo}`,\n  `👤 Cliente: ${cliente}`,\n  `👨‍⚖️ Responsável: ${responsavel}`,\n  `📅 Data: ${dataCriacao} | ⚠️ Prazo fatal: ${prazoFatal}`,\n  `🏷️ Tipo: ${tipo.label}`,\n  obsLimpa ? `\\n📝 Obs:\\n${obsLimpa}` : '',\n  `\\n🔢 ID DataJuri: ${r.id}`\n].filter(Boolean).join('\\n');\n\n// --- DATA de vencimento → ISO (de DD/MM/YYYY) ---\nconst dataVenc = r.dataPrazoFatal ? (() => {\n  const p = r.dataPrazoFatal.split('/');\n  return p.length === 3 ? `${p[2]}-${p[1]}-${p[0]}T12:00:00.000Z` : null;\n})() : null;\n\nreturn [{\n  json: {\n    titulo,\n    descricao,\n    dataVencimento: dataVenc,\n    labelCor: tipo.cor,\n    labelNome: tipo.label,\n    tipo: prefixo,\n    id_datajuri: r.id\n  }\n}];"
      },
