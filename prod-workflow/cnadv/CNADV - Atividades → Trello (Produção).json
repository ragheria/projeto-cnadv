        "jsCode": "return $input.all().map(item => {\n  const trelloId = item.json.id || '';\n  const desc = item.json.desc || '';\n  const match = desc.match(/ID:\\s*(\\d+)/);\n  const sourceId = match ? match[1] : '';\n  return { json: {\n    source_id: sourceId,\n    assunto: item.json.name || '',\n    trello_card_id: trelloId,\n    criado_em: new Date().toISOString()\n  } };\n});"
