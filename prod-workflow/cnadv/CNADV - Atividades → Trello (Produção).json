    {
      "parameters": {
        "jsCode": "const processadosIds = new Set(\n  $input.all()\n    .map(r => r.json.source_id)\n    .filter(id => id !== undefined && id !== null && id !== '')\n    .map(String)\n);\nconst atividades = $('Extrai Atividades').all();\nconst novas = atividades.filter(a => a.json.id !== undefined && !processadosIds.has(String(a.json.id)));\nif (novas.length === 0) return [];\nconsole.log('Atividades novas: ' + novas.length + ' de ' + atividades.length + ' do dia');\nreturn novas;"
      },
      "id": "75ae44f7-edd9-484d-8c9c-5b36f04c7fc3",
