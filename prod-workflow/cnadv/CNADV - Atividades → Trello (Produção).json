      "parameters": {
        "jsCode": "const rows = ($input.first().json.rows || [])\n  .filter(r => r.status !== 'Concluído');\nif (rows.length === 0) return [];\nconsole.log('Atividades do dia: ' + rows.length);\nreturn rows.map(r => ({ json: r }));"
